# Copy to var/gateway/local.env and adjust for your environment.

GATEWAY_PUBLIC_HOSTNAME=gateway.example.com
GATEWAY_WORKER_NAME=llestrade-gateway
GATEWAY_ONEPASSWORD_VAULT=LLestrade
GATEWAY_CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# macOS Keychain entry used to cache the 1Password service-account token.
GATEWAY_KEYCHAIN_SERVICE=llestrade.gateway
GATEWAY_KEYCHAIN_ACCOUNT=op-service-account-token

# 1Password secret references. UUID item IDs are supported.
GATEWAY_SERVICE_ACCOUNT_TOKEN_REF=op://LLestrade/odawngzy4edjpfqziyubhu4us4/credential
GATEWAY_CLOUDFLARE_API_TOKEN_REF=op://LLestrade/cloudflare-workers-api/token
GATEWAY_ANTHROPIC_API_KEY_REF=op://LLestrade/anthropic-api/key
GATEWAY_OPENAI_API_KEY_REF=op://LLestrade/openai-api/key
GATEWAY_GOOGLE_VERTEX_SERVICE_ACCOUNT_REF=op://LLestrade/google-vertex-service-account/credential
GATEWAY_APP_API_KEY_REF=op://LLestrade/pydantic-ai-gateway-app/key
GATEWAY_STATUS_API_KEY_REF=op://LLestrade/pydantic-ai-gateway-status/key

# Optional adaptive capacity tuning. These defaults are also applied automatically if omitted.
GATEWAY_ADAPTIVE_CAPACITY_ENABLED=true
GATEWAY_ADAPTIVE_CAPACITY_DEFAULT_INITIAL_LIMIT=8
GATEWAY_ADAPTIVE_CAPACITY_DEFAULT_MIN_LIMIT=1
GATEWAY_ADAPTIVE_CAPACITY_DEFAULT_MAX_LIMIT=32
GATEWAY_ADAPTIVE_CAPACITY_DEFAULT_COOLDOWN_MS=30000

# Optional per-provider overrides.
GATEWAY_ADAPTIVE_CAPACITY_ANTHROPIC_INITIAL_LIMIT=8
GATEWAY_ADAPTIVE_CAPACITY_ANTHROPIC_MIN_LIMIT=1
GATEWAY_ADAPTIVE_CAPACITY_ANTHROPIC_MAX_LIMIT=32
GATEWAY_ADAPTIVE_CAPACITY_ANTHROPIC_COOLDOWN_MS=30000

GATEWAY_ADAPTIVE_CAPACITY_OPENAI_INITIAL_LIMIT=8
GATEWAY_ADAPTIVE_CAPACITY_OPENAI_MIN_LIMIT=1
GATEWAY_ADAPTIVE_CAPACITY_OPENAI_MAX_LIMIT=32
GATEWAY_ADAPTIVE_CAPACITY_OPENAI_COOLDOWN_MS=30000

GATEWAY_ADAPTIVE_CAPACITY_GOOGLE_VERTEX_INITIAL_LIMIT=8
GATEWAY_ADAPTIVE_CAPACITY_GOOGLE_VERTEX_MIN_LIMIT=1
GATEWAY_ADAPTIVE_CAPACITY_GOOGLE_VERTEX_MAX_LIMIT=32
GATEWAY_ADAPTIVE_CAPACITY_GOOGLE_VERTEX_COOLDOWN_MS=30000
