# Anthropic API Configuration
ANTHROPIC_API_KEY=your_api_key_here

# Azure Document Intelligence API Configuration
AZURE_ENDPOINT=your_azure_endpoint_here
AZURE_KEY=your_azure_api_key_here

# Google Gemini API Configuration
# Get your API key from https://ai.google.dev/
# Required for processing large document summaries over 200k tokens
GEMINI_API_KEY=your_api_key_here

# AWS Bedrock Configuration
# Configure credentials with `aws configure` or `aws configure sso`.
# Optional overrides:
# AWS_PROFILE=default
# AWS_REGION=us-east-1

# Azure Document Intelligence API Configuration
AZURE_KEY=your_azure_di_api_key_here
AZURE_ENDPOINT=your_azure_di_endpoint_here

# Azure OpenAI
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=your_azure_openai_endpoint_key_here
# Example values - please leave the deplyment name as model name
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1
OPENAI_API_VERSION=2025-01-01-preview

# Pydantic AI Gateway
# Enable the Gateway-backed report + bulk-analysis path.
FRD_ENABLE_PYDANTIC_AI_GATEWAY=true
# Required for both the managed gateway and a self-hosted gateway.
PYDANTIC_AI_GATEWAY_API_KEY=your_gateway_api_key_here
# Optional for self-hosted gateway deployments on a custom domain.
PYDANTIC_AI_GATEWAY_BASE_URL=https://gateway.example.com
# Usually leave unset. Only override if your self-hosted deployment uses a non-default route.
# PYDANTIC_AI_GATEWAY_ROUTE=
# Optional shared request cap for the Gateway-backed worker path. Set to 0 to disable.
PYDANTIC_AI_GATEWAY_MAX_CONCURRENCY=4
